// symlink me to ~/{.config/Code,Library/Application Support/Trae{,CN}}/User/settings.json
{
    "extensions.supportUntrustedWorkspaces": {
        "byted-ide.dev-environment-manager": {
            "supported": true
        }
    },
    "remote.SSH.defaultExtensions": [
        "byted-ide.gallery",
        "byted-extensions.stratocube-remote-ssh"
    ],
    "editor.fontSize": 14,
    "files.autoSave": "onFocusChange",
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', SFMono Nerd Font, Menlo, Monaco, 'Courier New', monospace",
    "window.autoDetectColorScheme": true,
    "editor.aiStats.enabled": true,
    // "editor.experimentalGpuAcceleration": "on",
    "editor.experimental.treeSitterTelemetry": true,
    "editor.linkedEditing": true,
    "editor.guides.bracketPairs": "active",
    "terminal.integrated.confirmOnExit": "hasChildProcesses",
    "terminal.integrated.defaultProfile.osx": null,
    "terminal.integrated.enableImages": true,
    "zig.zls.enabled": "on",
    "terminal.integrated.persistentSessionScrollback": 100000000000,
    "terminal.integrated.scrollback": 10000000000,
    "editor.minimap.enabled": true,
    "editor.inlayHints.enabled": "on",
    "workbench.preferredLightColorTheme": "Light",
    "terminal.integrated.hideOnStartup": "whenEmpty",
    "terminal.integrated.shellIntegration.environmentReporting": true,
    "terminal.integrated.stickyScroll.enabled": true,
    "terminal.integrated.suggest.enabled": true,
    "git.blame.editorDecoration.enabled": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "zenMode.showTabs": "none",
    "terminal.integrated.tabs.title": "${process} (${cwdFolder})",
    "trae.tab.enableSummaryAutoDisplay": true,
    "trae.beta.enableAgentReviewOnCommit": true,
    "window.nativeTabs": true,
    "window.titleBarStyle": "native",
    "window.menuStyle": "inherit",
    "workbench.editor.customLabels.patterns": {
        "**/page.tsx": "${dirname}.page.tsx",
        "**/page.data.ts": "${dirname}.data.ts",
        "**/layout.tsx": "${dirname}.layout.tsx",
        "**/layout.data.ts": "${dirname}.layout.data.ts",
        "**/index.tsx": "${dirname}.index.tsx",
        "**/index.scss": "${dirname}.index.scss"
    },
    "git.blame.statusBarItem.enabled": true,
    "trae.tab.test.showCueflowFail": true,
    "trae.guide.neverShowNoticeForLanguages": [],
    "cSpell.userWords": [
        "bfcache",
        "BYTEFAAS",
        "Clawdbot",
        "connfd",
        "CONV",
        "creds",
        "crosskit",
        "csatmodalv",
        "Deeplink",
        "doubao",
        "ecom",
        "edenx",
        "EDITORCORE",
        "elementtiming",
        "fsopen",
        "larkcontact",
        "larkcore",
        "larkws",
        "libpython",
        "Lngs",
        "lraylib",
        "Navs",
        "oapi",
        "ollama",
        "rustc",
        "slardar",
        "smartlog",
        "Ssrd",
        "SSTBTM",
        "SSTCSAT",
        "sysconfig",
        "tokopedia",
        "TTFB",
        "Unkeyed",
        "volcengine"
    ],
    "better-comments.highlightPlainText": true,
    "byted-ide.clouddevUnitTestGeneration.commentLanguage": "English",
    "better-comments.tags": [
        {
            "tag": "@@@",
            "color": "#FF0000",
            "bold": true,
            "italic": true,
        }
    ],
    "chat.tools.terminal.outputLocation": "chat",
    "python.analysis.typeCheckingMode": "standard",
    "terminal.integrated.fontLigatures.enabled": true,
    "chat.tools.terminal.autoApprove": {
        "/^python .*/": true,
        "cd": true,
        "echo": true,
        "ls": true,
        "dir": true,
        "pwd": true,
        "cat": true,
        "head": true,
        "tail": true,
        "findstr": true,
        "wc": true,
        "tr": true,
        "cut": true,
        "cmp": true,
        "which": true,
        "basename": true,
        "dirname": true,
        "realpath": true,
        "readlink": true,
        "stat": true,
        "file": true,
        "od": true,
        "du": true,
        "df": true,
        "sleep": true,
        "nl": true,
        "grep": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+status\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+log\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+show\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+diff\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+ls-files\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+grep\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b.*\\s-(d|D|m|M|-delete|-force)\\b/": false,
        "/^docker\\s+(ps|images|info|version|inspect|logs|top|stats|port|diff|search|events)\\b/": true,
        "/^docker\\s+(container|image|network|volume|context|system)\\s+(ls|ps|inspect|history|show|df|info)\\b/": true,
        "/^docker\\s+compose\\s+(ps|ls|top|logs|images|config|version|port|events)\\b/": true,
        "Get-ChildItem": true,
        "Get-Content": true,
        "Get-Date": true,
        "Get-Random": true,
        "Get-Location": true,
        "Set-Location": true,
        "Write-Host": true,
        "Write-Output": true,
        "Out-String": true,
        "Split-Path": true,
        "Join-Path": true,
        "Start-Sleep": true,
        "Where-Object": true,
        "/^Select-[a-z0-9]/i": true,
        "/^Measure-[a-z0-9]/i": true,
        "/^Compare-[a-z0-9]/i": true,
        "/^Format-[a-z0-9]/i": true,
        "/^Sort-[a-z0-9]/i": true,
        "/^npm\\s+(ls|list|outdated|view|info|show|explain|why|root|prefix|bin|search|doctor|fund|repo|bugs|docs|home|help(-search)?)\\b/": true,
        "/^npm\\s+config\\s+(list|get)\\b/": true,
        "/^npm\\s+pkg\\s+get\\b/": true,
        "/^npm\\s+audit$/": true,
        "/^npm\\s+cache\\s+verify\\b/": true,
        "/^yarn\\s+(list|outdated|info|why|bin|help|versions)\\b/": true,
        "/^yarn\\s+licenses\\b/": true,
        "/^yarn\\s+audit\\b(?!.*\\bfix\\b)/": true,
        "/^yarn\\s+config\\s+(list|get)\\b/": true,
        "/^yarn\\s+cache\\s+dir\\b/": true,
        "/^pnpm\\s+(ls|list|outdated|why|root|bin|doctor)\\b/": true,
        "/^pnpm\\s+licenses\\b/": true,
        "/^pnpm\\s+audit\\b(?!.*\\bfix\\b)/": true,
        "/^pnpm\\s+config\\s+(list|get)\\b/": true,
        "npm ci": true,
        "/^yarn\\s+install\\s+--frozen-lockfile\\b/": true,
        "/^pnpm\\s+install\\s+--frozen-lockfile\\b/": true,
        "column": true,
        "/^column\\b.*\\s-c\\s+[0-9]{4,}/": false,
        "date": true,
        "/^date\\b.*\\s(-s|--set)\\b/": false,
        "find": true,
        "/^find\\b.*\\s-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
        "rg": true,
        "/^rg\\b.*\\s(--pre|--hostname-bin)\\b/": false,
        "sed": true,
        "/^sed\\b.*\\s(-[a-zA-Z]*(e|f)[a-zA-Z]*|--expression|--file)\\b/": false,
        "/^sed\\b.*s\\/.*\\/.*\\/[ew]/": false,
        "/^sed\\b.*;W/": false,
        "sort": true,
        "/^sort\\b.*\\s-(o|S)\\b/": false,
        "tree": true,
        "/^tree\\b.*\\s-o\\b/": false,
        "/^xxd$/": true,
        "/^xxd\\b(\\s+-\\S+)*\\s+[^-\\s]\\S*$/": true,
        "rm": false,
        "rmdir": false,
        "del": false,
        "Remove-Item": false,
        "ri": false,
        "rd": false,
        "erase": false,
        "dd": false,
        "kill": false,
        "ps": false,
        "top": false,
        "Stop-Process": false,
        "spps": false,
        "taskkill": false,
        "taskkill.exe": false,
        "curl": false,
        "wget": false,
        "Invoke-RestMethod": false,
        "Invoke-WebRequest": false,
        "irm": false,
        "iwr": false,
        "chmod": false,
        "chown": false,
        "Set-ItemProperty": false,
        "sp": false,
        "Set-Acl": false,
        "jq": false,
        "xargs": false,
        "eval": false,
        "Invoke-Expression": false,
        "iex": false
    },
    "chat.viewSessions.orientation": "stacked",
    "remote.SSH.remotePlatform": {
        "*cube-*": "linux"
    },
    "remote.defaultExtensionsIfInstalledLocally": [
        "byted-extensions.stratocube-remote-ssh"
    ],
    "cSpell.allowCompoundWords": true,
    "go.alternateTools": {
        "gopls": "trae-gopls"
    },
    "git.enableCommitSigning": true,
    "git.verboseCommit": true,
    "AI.toolcall.v2.ide.command.mode": "alwaysAsk",
    "AI.rules.importClaudeMd": true,
    "microsoft-sovereign-cloud.environment": "",
    "notebook.lineNumbers": "on",
    "chat.viewSessions.orientation": "stacked",
    "files.watcherExclude": {
        "**/.venv/**": true,
        "**/dist/**": true,
        "**/node_modules/**": true,
        "node_modules": true
    },
    "security.workspace.trust.untrustedFiles": "open",
    "tabnine.experimentalAutoImports": true
