{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/dotfiles/.config/opencode/introspection.md"
  ],
  "plugin": ["./plugin/conditional-bytedance.ts"],
  "mcp": {
    "Codebase": {
      "type": "remote",
      "url": "https://code.byted.org/api/mcp/codebase/mcp",
      "headers": {
        "X-Code-User-JWT": "{env:BYTED_AI_JWT}"
      }
    },
    "Lark": {
      "type": "remote",
      "url": "https://code.byted.org/api/mcp/lark/mcp",
      "headers": {
        "X-Code-User-JWT": "{env:BYTED_AI_JWT}"
      }
    },
    "ByteDance MCP": {
      "type": "remote",
      "url": "https://0r2y3xvu.mcp.bytedance.net/mcp",
      "headers": {
        "X-Code-User-JWT": "{env:BYTED_AI_JWT}"
      }
    },
    "Chrome DevTools": {
      "type": "local",
      "command": [
        "bunx",
        "chrome-devtools-mcp",
        "--channel=dev"
      ]
    },
    //"Trae_CLI": {
    //  "type": "local",
    //  "command": [
    //    "traecli",
    //    "mcp",
    //    "serve"
    //  ]
    //}
  },
  "permission": {
    "Codebase_GetFile": "ask",
    "Trae_CLI_Grep": "ask",
    "Trae_CLI_Read": "ask",
    "external_directory": {
      "/tmp/**": "allow",
      "~/code/github.com/anomalyco/opencode/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },

  "provider": {
    "openrouter": {
      "models": {
        "openrouter/pareto-code": {
          "variants": {
            "💩": {
              "plugins": [
                { "id": "pareto-router", "min_coding_score": 0.0 }
              ],
              "reasoning": { "effort": "none" },
              "limit": {
                "context": 100000
              }
            },
            "low": {
              "plugins": [
                { "id": "pareto-router", "min_coding_score": 0.1 }
              ],
            },
            "medium": {
              "plugins": [
                { "id": "pareto-router", "min_coding_score": 0.34 }
              ]
            },
            "high": {
              "plugins": [
                { "id": "pareto-router", "min_coding_score": 0.67 }
              ],
            },
            "🤩": {
              "plugins": [
                { "id": "pareto-router", "min_coding_score": 1 }
              ],
              "reasoning": { "effort": "xhigh" },
              "limit": {
                "context": 1048576
              }
            }
          }
        }
      }
    },
    "ai_agent_proxy_chat": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AI Agent Proxy Chat",
      "options": {
        "baseURL": "https://ai-coder.bytedance.net",
        "apiKey": "{env:BYTED_AI_CODER_API_KEY}",
        "headers": {}
      },
      "models": {
        "kimi-k2.5-gpt": {
          "name": "Kimi-K2.5",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "kimi-k2-gpt": {
          "name": "Kimi-K2",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "kimi-k2-thinking": {
          "name": "Kimi-K2-Thinking",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
