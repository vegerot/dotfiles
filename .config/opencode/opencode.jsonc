    "ai_agent_proxy_google": {
      "npm": "@ai-sdk/google",
      "name": "AI Agent Proxy Google",
      "options": {
        "baseURL": "https://ai-coder.bytedance.net/gemini/v1beta",
        "apiKey": "{env:BYTED_AI_CODER_API_KEY}",
