{
  "mcpServers": {
    "Codebase": {
      "type": "http",
      "url": "https://code.byted.org/api/mcp/codebase/mcp",
      "tools": [
        "*"
      ],
      "headers": {
        "X-Code-User-JWT": "${env:BYTED_AI_JWT}"
      }
    },
    "Lark": {
      "type": "http",
      "url": "https://code.byted.org/api/mcp/lark/mcp",
      "tools": [
        "*"
      ],
      "headers": {
        "X-Code-User-JWT": "${env:BYTED_AI_JWT}"
      }
    },
    "ByteDance MCP": {
      "type": "http",
      "url": "https://0r2y3xvu.mcp.bytedance.net/mcp",
      "tools": [
        "*"
      ],
      "headers": {
        "X-Code-User-JWT": "${env:BYTED_AI_JWT}"
      }
    },
    "Chrome DevTools": {
      "type": "local",
      "command": "bunx",
      "args": [
        "chrome-devtools-mcp",
        "--channel=dev"
      ],
      "tools": [
        "*"
      ]
    }
  }
}
