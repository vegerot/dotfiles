{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": true,
    "enableAutoUpdateNotification": false
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md",
      "CLAUDE.md",
      "README.md",
      "introspection.md"
    ]
  },
  "ui": {
    "errorVerbosity": "full"
  },
  "mcpServers": {
    "Codebase": {
      "url": "https://code.byted.org/api/mcp/codebase/mcp",
      "headers": {
        "X-Code-User-JWT": "$BYTED_AI_JWT"
      }
    },
    "Lark": {
      "url": "https://code.byted.org/api/mcp/lark/mcp",
      "headers": {
        "X-Code-User-JWT": "$BYTED_AI_JWT"
      }
    },
    "ByteDance-MCP": {
      "url": "https://0r2y3xvu.mcp.bytedance.net/mcp",
      "headers": {
        "X-Code-User-JWT": "$BYTED_AI_JWT"
      }
    },
    "Chrome-DevTools": {
      "command": "bunx",
      "args": [
        "chrome-devtools-mcp",
        "--channel=dev"
      ]
    },
    "Firefox-MCP": {
      "command": "bunx",
      "args": [
        "firefox-devtools-mcp@latest",
        "--firefox-path='/Applications/Firefox Developer Edition.app/Contents/MacOS/firefox'",
        "--enable-script",
        "--enable-privileged-context",
        "--marionette"
      ]
    }
  }
}
