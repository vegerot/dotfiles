#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

# List all repositories in the current directory

main() {
	local ignore_arg=""
	if fd --help | grep -q -- "--ignore-contain"; then
		ignore_arg="--ignore-contain=.git"
	fi
	if [[ ${1:-} == "deep" ]]; then
		shift
		fd '^\.(git|sl)$' "$@" \
			--max-depth=10 --hidden --type=d --follow --prune ${ignore_arg} \
			--exec dirname {} \; \
			| sort
	else
		fd '^.git$' "$@" \
			--max-depth=5 --hidden --type=d --follow --prune ${ignore_arg} \
			--exec dirname {} \; \
			| sort
	fi
}

main $@
